{
  "name": "nutribucks",
  "version": "1.0.0",
  "private": true,
  "description": "NutriBucks — a fast, SEO-first Starbucks nutrition calculator (static-generated).",
  "scripts": {
    "render": "python src/build.py",
    "css": "tailwindcss -i ./src/assets/app.css -o ./dist/assets/app.css --minify",
    "css:watch": "tailwindcss -i ./src/assets/app.css -o ./dist/assets/app.css --watch",
    "build": "python src/build.py && tailwindcss -i ./src/assets/app.css -o ./dist/assets/app.css --minify",
    "serve": "python -m http.server 8080 --directory dist"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/container-queries": "^0.1.1"
  }
}
